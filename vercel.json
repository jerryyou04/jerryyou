{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/resume",
      "destination": "/resume.pdf",
      "permanent": false
    },
    {
      "source": "/resume/resume.pdf",
      "destination": "/resume.pdf",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/resume.pdf",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Content-Disposition",
          "value": "inline; filename=\"Jerry-You-Resume.pdf\""
        }
      ]
    }
  ]
}
